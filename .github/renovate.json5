{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>kitware-resonant/.github:renovate-library.json5',
  ],
  packageRules: [
    // Separate pytest-django from the grouped updates — the latest version is
    // broken and would hold back all other dependency updates.
    {
      matchPackageNames: ['pytest-django'],
      groupName: 'pytest-django',
      groupSlug: 'pytest-django',
    },
  ],
}
